# Copy to .env and fill in values from the Discord Developer Portal.

APP_NAME=WoSB Guild
SECRET_KEY=replace-with-long-random-string

# sqlite file for local dev; use postgresql+asyncpg://... for production
DATABASE_URL=sqlite+aiosqlite:///./wosb.db

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:8000/auth/callback

# Bot must be invited to your server. Used to read a member's roles after OAuth.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Right-click roles in Discord (Developer Mode on) and copy IDs
DISCORD_ROLE_ADMIRAL_ID=
DISCORD_ROLE_LEADER_ID=
DISCORD_ROLE_ALLIANCE_LEADER_ID=

# Optional: one role per guild — on sign-in, home guild tag is set from these (first match wins: TIF → BWC → SVA → LP).
DISCORD_ROLE_GUILD_TIF_ID=
DISCORD_ROLE_GUILD_BWC_ID=
DISCORD_ROLE_GUILD_SVA_ID=
DISCORD_ROLE_GUILD_LP_ID=

# Guild pages list everyone with the matching role. The bot needs Server Members Intent + permission to read members.

# Optional: JPEG/PNG/WebP you placed under ./static/images/ (served at /static/...)
# SITE_BACKGROUND_IMAGE=/static/images/your-harbour.jpg
