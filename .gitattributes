# Normalize text files to LF in the repository.
* text=auto eol=lf

# Keep native Windows line endings for Windows shell scripts.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Keep Unix line endings for Unix shell scripts.
*.sh text eol=lf

# Common binary formats (never attempt line-ending normalization).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
